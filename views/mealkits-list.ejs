<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Meal Kits List</h1>
    <div>
      <a href="/load-data/mealkits" class="btn btn-outline-secondary me-2">Load Data</a>
      <a href="/mealkits/add" class="btn btn-primary">Add Meal Kit</a>
    </div>
  </div>

  <% if (!kits.length) { %>
    <div class="alert alert-info">No meal kits found.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>Image</th>
            <th>Title</th>
            <th>Category</th>
            <th>Price</th>
            <th>Featured</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% kits.forEach(kit => { %>
            <tr>
              <td style="width: 120px;">
                <img
                  src="<%= kit.imageUrl %>"
                  alt="<%= kit.title %>"
                  class="img-fluid rounded"
                  style="max-height: 80px; object-fit: cover;"
                >
              </td>
              <td><%= kit.title %></td>
              <td><%= kit.category %></td>
              <td>$<%= Number(kit.price).toFixed(2) %></td>
              <td><%= kit.featuredMealKit ? "Yes" : "No" %></td>
              <td>
                <a href="/mealkits/edit/<%= kit._id %>" class="btn btn-sm btn-warning me-2">Edit</a>
                <a href="/mealkits/remove/<%= kit._id %>" class="btn btn-sm btn-danger">Delete</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>