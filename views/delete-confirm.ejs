<div class="container py-5" style="max-width: 700px;">
  <h1 class="mb-4 text-danger">Delete Meal Kit</h1>

  <div class="card">
    <div class="card-body">
      <div class="row align-items-center">
        <div class="col-md-4 mb-3 mb-md-0">
          <img
            src="<%= kit.imageUrl %>"
            alt="<%= kit.title %>"
            class="img-fluid rounded"
          >
        </div>

        <div class="col-md-8">
          <h4><%= kit.title %></h4>
          <p class="mb-1"><strong>Category:</strong> <%= kit.category %></p>
          <p class="mb-1"><strong>Price:</strong> $<%= Number(kit.price).toFixed(2) %></p>
          <p class="mb-3"><strong>Includes:</strong> <%= kit.includes %></p>

          <p class="text-danger fw-bold">
            Are you sure you want to delete this meal kit?
          </p>

          <form method="POST" action="/mealkits/remove/<%= kit._id %>">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a href="/mealkits/list" class="btn btn-secondary ms-2">Cancel</a>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>