<div class="container py-5" style="max-width: 800px;">
  <h1 class="mb-4">Edit Meal Kit</h1>

  <form method="POST" action="/mealkits/edit/<%= kit._id %>" enctype="multipart/form-data" class="border rounded p-4 bg-light">
    <div class="mb-3">
      <label class="form-label">Title</label>
      <input type="text" name="title" class="form-control" value="<%= kit.title %>" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Includes</label>
      <input type="text" name="includes" class="form-control" value="<%= kit.includes %>" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Description</label>
      <textarea name="description" class="form-control" rows="4" required><%= kit.description %></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label">Category</label>
      <input type="text" name="category" class="form-control" value="<%= kit.category %>" required>
    </div>

    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label">Price</label>
        <input type="number" name="price" class="form-control" min="0.01" step="0.01" value="<%= kit.price %>" required>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Cooking Time (minutes)</label>
        <input type="number" name="cookingTime" class="form-control" min="1" step="1" value="<%= kit.cookingTime %>" required>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Servings</label>
        <input type="number" name="servings" class="form-control" min="1" step="1" value="<%= kit.servings %>" required>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label d-block">Current Image</label>
      <img
        src="<%= kit.imageUrl %>"
        alt="<%= kit.title %>"
        class="img-fluid rounded mb-2"
        style="max-height: 180px; object-fit: cover;"
      >
    </div>

    <div class="mb-3">
      <label class="form-label">Replace Image</label>
      <input type="file" name="imageUrl" class="form-control" accept=".jpg,.jpeg,.png,.gif">
    </div>

    <div class="form-check mb-4">
      <input
        class="form-check-input"
        type="checkbox"
        name="featuredMealKit"
        id="featuredMealKit"
        <%= kit.featuredMealKit ? "checked" : "" %>
      >
      <label class="form-check-label" for="featuredMealKit">
        Featured Meal Kit
      </label>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="/mealkits/list" class="btn btn-secondary ms-2">Cancel</a>
  </form>
</div>