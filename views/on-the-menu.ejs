<section class="py-5">
  <div class="container">
    <h1 class="mb-4">On the Menu</h1>

    <% categories.forEach(cat => { %>
      <div class="mb-5">
        <h2 class="mb-3"><%= cat.categoryName %></h2>

        <div class="row g-4 row-cols-1 row-cols-md-2 row-cols-lg-3">
          <% cat.mealKits.forEach(mk => { %>
            <div class="col">
              <%- include("partials/mealkit", { mealkit: mk }) %>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</section>
